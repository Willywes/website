---
const logos = [
    "astro",
    "bootstrap",
    "css",
    "django",
    "electron",
    "expressjs",
    "graphql",
    "html5",
    "javascript",
    "jquery",
    "kotlin",
    "laravel",
    "mysql",
    "nextjs",
    "nodejs",
    "php",
    "postgresql",
    "python",
    "react",
    "sass",
    "solidjs",
    "supabase",
    "tailwindcss",
    "typescript",
    "vue",
    "zod",
];

// Lenguajes
const langs = ["javascript", "typescript", "python", "php", "kotlin"];

const backendFrameworks = ["django", "expressjs", "laravel", "nodejs", "php"];
// Frameworks
const FrontFrameworks = [
    "astro",
    "bootstrap",
    "nextjs",
    "react",
    "solidjs",
    "supabase",
    "tailwindcss",
    "vue",
];

// Bases de datos
const databases = ["mysql", "postgresql", "supabase", "mariadb"];

// Herramientas
const tools = ["electron", "graphql", "jquery", "zod"];
---

<section id="what-i-have-learned" class="min-h-screen py-12 md:py-24">
    <div class="grid gap-24">
        <div class="grid gap-12 text-center max-w-4xl mx-auto">
            <h2 class="text-4xl sm:text-6xl font-bold">What I've learned</h2>
            <p class="w-full text-lg">
                I'm learning new things every day. I'm always looking for new
                challenges and opportunities to grow as a developer. This are
                some of the things I've learned so far.
            </p>
        </div>

        <div class="grid gap-12">
            <div class="grid gap-6 text-center max-w-xl mx-auto">
                <h2 class="text-3xl sm:text-4xl font-bold">Languages</h2>
                <p class="w-full text-lg">
                    I've learned a few languages, but I'm always looking to
                    learn more. I'm currently learning Kotlin and I'm planning
                    to learn Rust in the future.
                </p>
            </div>
            <div class="flex flex-wrap justify-center gap-12">
                {
                    langs.map((lang) => (
                        <img
                            src={`/logos/${lang}.svg`}
                            alt={lang}
                            class="inline-block w-12 h-12 sm:w-16 sm:h-16"
                        />
                    ))
                }
            </div>
        </div>

        <div class="grid gap-12">
            <div class="grid gap-6 text-center max-w-xl mx-auto">
                <h2 class="text-3xl sm:text-4xl font-bold">Backend</h2>
                <p class="w-full text-lg">
                    I've learned a few languages, but I'm always looking to
                    learn more. I'm currently learning Kotlin and I'm planning
                    to learn Rust in the future.
                </p>
            </div>
            <div class="flex flex-wrap justify-center gap-12">
                {
                    backendFrameworks.map((lang) => (
                        <img
                            src={`/logos/${lang}.svg`}
                            alt={lang}
                            class="inline-block w-12 h-12 sm:w-16 sm:h-16"
                        />
                    ))
                }
            </div>
        </div>
    </div>
</section>
