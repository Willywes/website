---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Opps! Not found">
    <div
        class="container container-xl mx-auto flex flex-col items-center justify-center min-h-screen gap-6"
    >
        <h1 class="text-9xl font-bold text-yellow-500">404</h1>
        <h2 class="text-4xl font-bold">Opps! Not found</h2>

        <p class="text-lg">The page you are looking for does not exist.</p>
        <a href="/" class="text-lg text-yellow-500 hover:text-yellow-400">
            Go back to home
        </a>
    </div>
</Layout>
